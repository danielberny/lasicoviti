###  http://www.semanticweb.org/2026/lasicoviti#Grizon
:Grizon rdf:type owl:Class ;
        rdfs:subClassOf :Zivocich ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :maMistoVyskytu ;
                          owl:someValuesFrom :JizniAmerika
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :maMistoVyskytu ;
                          owl:someValuesFrom :JizniMexiko
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :maMistoVyskytu ;
                          owl:someValuesFrom :StredniAmerika
                        ] .


