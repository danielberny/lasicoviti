@prefix : <http://www.semanticweb.org/2026/lasicoviti#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/2026/lasicoviti#> .

<http://www.semanticweb.org/2026/lasicoviti> rdf:type owl:Ontology ;
                                              rdfs:comment "Ontologie zabývající se lasicovitými šelmami" .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/2026/lasicoviti#jeCeledi
:jeCeledi rdf:type owl:ObjectProperty ;
          owl:inverseOf :patriDoCeledi ;
          rdfs:domain :Celed ;
          rdfs:range :Zivocich .


###  http://www.semanticweb.org/2026/lasicoviti#jeMistoVyskytuPro
:jeMistoVyskytuPro rdf:type owl:ObjectProperty ;
                   owl:inverseOf :maMistoVyskytu ;
                   rdfs:domain :MistoVyskytu ;
                   rdfs:range :Zivocich .


###  http://www.semanticweb.org/2026/lasicoviti#jePodceledi
:jePodceledi rdf:type owl:ObjectProperty ;
             owl:inverseOf :partiDoPodceledi ;
             rdfs:domain :Podceled ;
             rdfs:range :Zivocich .


###  http://www.semanticweb.org/2026/lasicoviti#jeRodu
:jeRodu rdf:type owl:ObjectProperty ;
        owl:inverseOf :patriDoRodu ;
        rdfs:domain :Rod ;
        rdfs:range :Zivocich .


###  http://www.semanticweb.org/2026/lasicoviti#maMistoVyskytu
:maMistoVyskytu rdf:type owl:ObjectProperty ;
                rdfs:domain :Zivocich ;
                rdfs:range :MistoVyskytu .


###  http://www.semanticweb.org/2026/lasicoviti#partiDoPodceledi
:partiDoPodceledi rdf:type owl:ObjectProperty ;
                  rdfs:domain :Zivocich ;
                  rdfs:range :Podceled .


###  http://www.semanticweb.org/2026/lasicoviti#patriDoCeledi
:patriDoCeledi rdf:type owl:ObjectProperty ;
               rdfs:domain :Zivocich ;
               rdfs:range :Celed .


###  http://www.semanticweb.org/2026/lasicoviti#patriDoRodu
:patriDoRodu rdf:type owl:ObjectProperty ;
             rdfs:domain :Zivocich ;
             rdfs:range :Rod .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/2026/lasicoviti#Afrika
:Afrika rdf:type owl:Class ;
        rdfs:subClassOf :MistoVyskytu .


###  http://www.semanticweb.org/2026/lasicoviti#Arctonyx
:Arctonyx rdf:type owl:Class ;
          rdfs:subClassOf :Melinae ,
                          :Rod .


###  http://www.semanticweb.org/2026/lasicoviti#Asie
:Asie rdf:type owl:Class ;
      rdfs:subClassOf :MistoVyskytu .


###  http://www.semanticweb.org/2026/lasicoviti#Celed
